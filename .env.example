# Copy to a local untracked .env file or configure these in the hosting secret store.
BANK_ENV=local
# Required in Staging so a mislabeled environment cannot target another PostgreSQL project.
BANK_STAGING_DATABASE_HOST=staging.example.invalid
# Migration/import must use a direct endpoint and a schema-owner role.
DATABASE_MIGRATOR_URL=postgresql://banke_migrator:change-me@127.0.0.1:5432/banke?sslmode=verify-full
# Runtime API must use a separate least-privilege role; a pooler is allowed.
# Production must use the dedicated banke_api_production role and explicitly name /neondb.
DATABASE_API_URL=postgresql://banke_api:change-me@127.0.0.1:5432/banke?sslmode=verify-full
DATABASE_SSL=disable
DATABASE_POOL_MAX=10
# Required only for the destructive, staging-only restore rehearsal.
BANK_STAGING_RESTORE_CONFIRM=
# Optional PostgreSQL client-tool directory (pg_dump and pg_restore).
POSTGRES_BIN=C:\Program Files\PostgreSQL\18\bin
BANK_ALLOWED_ORIGINS=http://127.0.0.1:4173
# OIDC access-token verification. Use isolated Staging tenant identifiers here;
# these identifiers are not secrets, but they must never point at Production.
BANK_OIDC_ISSUER=https://staging-tenant.example.invalid/
BANK_OIDC_AUDIENCE=https://bankeban-staging-api
BANK_OIDC_JWKS_URL=https://staging-tenant.example.invalid/.well-known/jwks.json
BANK_OIDC_SESSION_CLAIM=https://banke.tw/session_id
# Generate a 32-byte value and encode it as base64url. Store the real key only
# in the environment/secret manager; rotate BANK_TENANT_CONTEXT_KEY_ID with it.
BANK_TENANT_CONTEXT_KEY=replace-with-32-byte-base64url-secret
BANK_TENANT_CONTEXT_KEY_ID=staging-context-key-1
PORT=8080
